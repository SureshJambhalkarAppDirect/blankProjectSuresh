# ScreenPal credentials (do not commit .env)
# Copy to .env and fill in your values:
# cp .env.example .env

SCREENPAL_EMAIL=your-email@example.com
SCREENPAL_PASSWORD=your-password

# Optional: run browser visibly (default: false = headless)
# HEADED=true

# Optional: if your library is at a different URL
# SCREENPAL_LIBRARY_URL=https://www.screenpal.com/your/library/path
